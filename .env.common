# Shared environment values across services
# Keep only common knobs here; put service-only values in each service env file.

DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=12345678
DB_CONNECTION_TIMEOUT=30000
DB_MAX_POOL_SIZE=10
DB_MIN_IDLE=2
JPA_SHOW_SQL=false

INTERNAL_API_KEY=change-me
GATEWAY_API_KEY=my-secret-gateway-key

HTTP_CLIENT_CONNECT_TIMEOUT_MS=5000
HTTP_CLIENT_RESPONSE_TIMEOUT_SECONDS=10

