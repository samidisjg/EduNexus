{
  "info": {
    "_postman_id": "1d6eaf5f-3c0f-4e47-94e6-fine-service",
    "name": "EduNexus Fine Service",
    "description": "Postman collection for all public and internal Fine Service endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Public APIs",
      "item": [
        {
          "name": "Get All Fines",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/fines",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "fines"
              ]
            }
          }
        },
        {
          "name": "Get Fine By Fine Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/fines/{{fineId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "fines",
                "{{fineId}}"
              ]
            }
          }
        },
        {
          "name": "Get Fines By Student Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/fines/student/{{studentId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "fines",
                "student",
                "{{studentId}}"
              ]
            }
          }
        },
        {
          "name": "Pay Fine",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentMethod\": \"CARD\",\n  \"amount\": 500.00,\n  \"referenceNote\": \"Paid via demo checkout\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/fines/{{fineId}}/pay",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "fines",
                "{{fineId}}",
                "pay"
              ]
            }
          }
        },
        {
          "name": "Get Payments By Fine Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/fines/{{fineId}}/payments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "fines",
                "{{fineId}}",
                "payments"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Internal APIs",
      "item": [
        {
          "name": "Calculate Fine",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-INTERNAL-KEY",
                "value": "{{internalApiKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"borrowId\": 1,\n  \"studentId\": \"IT22607232\",\n  \"daysLate\": 5\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/internal/fines/calculate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "internal",
                "fines",
                "calculate"
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8084/fine-service"
    },
    {
      "key": "fineId",
      "value": "FINE-001"
    },
    {
      "key": "studentId",
      "value": "IT22607232"
    },
    {
      "key": "internalApiKey",
      "value": "my-secret-internal-key"
    }
  ]
}
