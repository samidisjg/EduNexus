{
  "info": {
    "name": "User Service API",
    "description": "User Service Authentication & Authorization API endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Sign Up",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"john_doe\",\n  \"userEmail\": \"john@example.com\",\n  \"userPassword\": \"SecurePassword123\",\n  \"role\": \"USER\"\n}"
            },
            "url": {
              "raw": "http://localhost:9091/user-service/auth/sign-up",
              "protocol": "http",
              "host": ["localhost"],
              "port": "9091",
              "path": ["user-service", "auth", "sign-up"]
            }
          }
        },
        {
          "name": "Sign In",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userEmail\": \"john@example.com\",\n  \"userPassword\": \"SecurePassword123\"\n}"
            },
            "url": {
              "raw": "http://localhost:9091/user-service/auth/sign-in",
              "protocol": "http",
              "host": ["localhost"],
              "port": "9091",
              "path": ["user-service", "auth", "sign-in"]
            }
          }
        },
        {
          "name": "Validate Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:9091/user-service/auth/validate-token",
              "protocol": "http",
              "host": ["localhost"],
              "port": "9091",
              "path": ["user-service", "auth", "validate-token"]
            }
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:9091/user-service/auth/user/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "9091",
              "path": ["user-service", "auth", "user", "1"]
            }
          }
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:9091/user-service/auth/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "9091",
              "path": ["user-service", "auth", "health"]
            }
          }
        }
      ]
    },
    {
