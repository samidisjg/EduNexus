                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"jane_smith\",\n  \"userEmail\": \"jane@example.com\",\n  \"userPassword\": \"SecurePassword456\",\n  \"role\": \"ADMIN\"\n}"
            },
            "url": {
              "raw": "http://localhost:8081/api-gateway/user-service/auth/sign-up",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["api-gateway", "user-service", "auth", "sign-up"]
            }
          }
        },
        {
          "name": "Sign In (Gateway)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userEmail\": \"jane@example.com\",\n  \"userPassword\": \"SecurePassword456\"\n}"
            },
            "url": {
              "raw": "http://localhost:8081/api-gateway/user-service/auth/sign-in",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["api-gateway", "user-service", "auth", "sign-in"]
            }
          }
        },
        {
          "name": "Student - Add Student (Protected)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentName\": \"Alice Johnson\",\n  \"email\": \"alice@example.com\"\n}"
            },
            "url": {
              "raw": "http://localhost:8081/api-gateway/student-service/students",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
