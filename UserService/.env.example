# Environment Variables Template for User Service
# Copy this file to .env and update with your actual values

# Server Configuration
SERVER_PORT=9091

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=user_db
DB_USERNAME=root
DB_PASSWORD=12345678
DB_CONNECTION_TIMEOUT=30000
DB_MAX_POOL_SIZE=10
DB_MIN_IDLE=2

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production-at-least-256-bit-long
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=86400000

# JPA Configuration
JPA_SHOW_SQL=false

